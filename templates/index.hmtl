<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auto Trade | Next Gen Terminal</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Orbitron', monospace;
            background: #000;
            overflow: hidden;
            height: 100vh;
        }

        #bg-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
        }

        .terminal {
            position: relative;
            z-index: 10;
            width: 100%;
            height: 100vh;
            display: flex;
            flex-direction: column;
            backdrop-filter: blur(5px);
        }

        .header {
            padding: 20px 40px;
            background: linear-gradient(135deg, rgba(139, 0, 255, 0.3), rgba(0, 255, 255, 0.1));
            border-bottom: 1px solid rgba(0, 255, 255, 0.5);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .logo h1 {
            font-family: 'Orbitron', monospace;
            font-size: 28px;
            background: linear-gradient(135deg, #ff00ff, #00ffff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: glow 2s ease-in-out infinite alternate;
        }

        @keyframes glow {
            from { text-shadow: 0 0 10px rgba(0, 255, 255, 0.5); }
            to { text-shadow: 0 0 30px rgba(255, 0, 255, 0.8); }
        }

        .status {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .live-badge {
            background: #ff00ff33;
            padding: 8px 20px;
            border-radius: 40px;
            border: 1px solid #ff00ff;
            font-size: 14px;
            font-weight: bold;
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .time-badge {
            background: #000000aa;
            padding: 8px 20px;
            border-radius: 40px;
            font-family: monospace;
            font-size: 14px;
            backdrop-filter: blur(5px);
            color: #00ffff;
        }

        .dashboard {
            flex: 1;
            padding: 20px 40px;
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            overflow: hidden;
        }

        .info-panel {
            flex: 1;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            border: 1px solid rgba(0, 255, 255, 0.3);
            padding: 20px;
            min-width: 280px;
        }

        .info-panel h3 {
            color: #00ffff;
            margin-bottom: 15px;
            font-size: 18px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.05);
            padding: 15px;
            border-radius: 15px;
            text-align: center;
        }

        .stat-value {
            font-size: 32px;
            font-weight: bold;
            background: linear-gradient(135deg, #ff00ff, #00ffff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .stat-label {
            font-size: 11px;
            color: #aaa;
            margin-top: 5px;
        }

        .signals-panel {
            flex: 2;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            border: 1px solid rgba(0, 255, 255, 0.3);
            padding: 20px;
            min-width: 400px;
            display: flex;
            flex-direction: column;
        }

        .signals-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .signals-header h3 {
            color: #00ffff;
            font-size: 18px;
        }

        .filter-input {
            background: rgba(0, 0, 0, 0.7);
            border: 1px solid #ff00ff;
            color: #fff;
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 12px;
        }

        .filter-input:focus {
            outline: none;
            border-color: #00ffff;
        }

        .signals-container {
            flex: 1;
            overflow-y: auto;
            padding-right: 5px;
        }

        .signal-card {
            background: linear-gradient(135deg, rgba(255, 0, 255, 0.1), rgba(0, 255, 255, 0.05));
            border-radius: 15px;
            padding: 15px;
            margin-bottom: 10px;
            border-left: 4px solid #ff00ff;
            cursor: pointer;
            transition: all 0.3s;
        }

        .signal-card:hover {
            transform: translateX(5px);
            background: rgba(255, 0, 255, 0.2);
        }

        .signal-symbol {
            font-size: 18px;
            font-weight: bold;
        }

        .signal-action {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }

        .buy { background: #00ff88; color: #000; }
        .sell { background: #ff4444; color: #fff; }

        .footer {
            text-align: center;
            padding: 15px;
            font-size: 11px;
            color: #666;
            background: rgba(0, 0, 0, 0.5);
        }

        .signals-container::-webkit-scrollbar {
            width: 5px;
        }
        .signals-container::-webkit-scrollbar-track {
            background: #1a1a2e;
        }
        .signals-container::-webkit-scrollbar-thumb {
            background: #ff00ff;
            border-radius: 10px;
        }

        @media (max-width: 768px) {
            .header { padding: 15px; }
            .dashboard { padding: 15px; }
            .info-panel, .signals-panel { min-width: 100%; }
        }
    </style>
</head>
<body>

    <canvas id="bg-canvas"></canvas>

    <div class="terminal">
        <div class="header">
            <div class="logo">
                <h1>⚡ AUTO TRADE ⚡</h1>
            </div>
            <div class="status">
                <div class="live-badge">🟢 LIVE DATA</div>
                <div class="time-badge" id="liveTime">--:--:--</div>
            </div>
        </div>

        <div class="dashboard">
            <div class="info-panel">
                <h3>📊 СТАТИСТИКА</h3>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-value" id="totalSignals">0</div>
                        <div class="stat-label">ВСЕГО</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="buySignals">0</div>
                        <div class="stat-label">BUY</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="sellSignals">0</div>
                        <div class="stat-label">SELL</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="accuracy">75%</div>
                        <div class="stat-label">ТОЧНОСТЬ</div>
                    </div>
                </div>
            </div>

            <div class="signals-panel">
                <div class="signals-header">
                    <h3>🎯 СИГНАЛЫ В РЕАЛЬНОМ ВРЕМЕНИ</h3>
                    <input type="text" id="searchFilter" class="filter-input" placeholder="🔍 Поиск монеты..." onkeyup="filterSignals()">
                </div>
                <div class="signals-container" id="signalsContainer">
                    <div style="text-align: center; padding: 40px; color: #888;">
                        ⏳ Загрузка сигналов...
                    </div>
                </div>
            </div>
        </div>

        <div class="footer">
            🔮 Киберпанк терминал | Клик по сигналу → график Bybit | Мульти-индикаторный анализ
        </div>
    </div>

    <script>
        // ========== 3D КИБЕРПАНК ФОН ==========
        (function init3D() {
            const scene = new THREE.Scene();
            scene.background = new THREE.Color(0x050510);
            
            const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.set(0, 0, 15);
            
            const renderer = new THREE.WebGLRenderer({ canvas: document.getElementById('bg-canvas'), alpha: false });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            
            const gridHelper = new THREE.GridHelper(30, 40, 0xff00ff, 0x00ffff);
            gridHelper.position.y = -3;
            scene.add(gridHelper);
            
            const geometry = new THREE.BoxGeometry(3, 3, 3);
            const edges = new THREE.EdgesGeometry(geometry);
            const wireframe = new THREE.LineSegments(edges, new THREE.LineBasicMaterial({ color: 0xff00ff }));
            scene.add(wireframe);
            
            const particleCount = 1500;
            const particlesGeometry = new THREE.BufferGeometry();
            const particlesPositions = new Float32Array(particleCount * 3);
            
            for (let i = 0; i < particleCount; i++) {
                particlesPositions[i * 3] = (Math.random() - 0.5) * 50;
                particlesPositions[i * 3 + 1] = (Math.random() - 0.5) * 30;
                particlesPositions[i * 3 + 2] = (Math.random() - 0.5) * 30 - 15;
            }
            
            particlesGeometry.setAttribute('position', new THREE.BufferAttribute(particlesPositions, 3));
            const particlesMaterial = new THREE.PointsMaterial({ color: 0x00ffff, size: 0.08 });
            const particles = new THREE.Points(particlesGeometry, particlesMaterial);
            scene.add(particles);
            
            const ambientLight = new THREE.AmbientLight(0x404060);
            scene.add(ambientLight);
            const pointLight = new THREE.PointLight(0xff00ff, 1, 30);
            pointLight.position.set(2, 3, 4);
            scene.add(pointLight);
            
            let time = 0;
            
            function animate() {
                requestAnimationFrame(animate);
                time += 0.005;
                
                wireframe.rotation.x = time * 0.3;
                wireframe.rotation.y = time * 0.5;
                particles.rotation.y = time * 0.05;
                gridHelper.rotation.z = Math.sin(time * 0.1) * 0.1;
                
                renderer.render(scene, camera);
            }
            
            animate();
            
            window.addEventListener('resize', () => {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });
        })();
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script>
        // ========== ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ ==========
        let allSignals = [];
        let previousSignalsCount = 0;

        // ========== ФУНКЦИЯ ОТКРЫТИЯ BYBIT ==========
        window.openBybitChart = function(symbol) {
            if (!symbol) return;
            let cleanSymbol = symbol.replace('/USDT', '').replace('USDT', '');
            let url = `https://www.bybit.com/trade/spot/${cleanSymbol}/USDT?interval=60`;
            window.open(url, '_blank');
        };

        // ========== ЗВУК ПРИ НОВОМ СИГНАЛЕ ==========
        function playAlertSound() {
            try {
                const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                const oscillator = audioCtx.createOscillator();
                const gainNode = audioCtx.createGain();
                oscillator.connect(gainNode);
                gainNode.connect(audioCtx.destination);
                oscillator.frequency.value = 880;
                gainNode.gain.value = 0.3;
                oscillator.start();
                gainNode.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + 0.5);
                oscillator.stop(audioCtx.currentTime + 0.5);
            } catch(e) {
                console.log('Звук не поддерживается');
            }
        }

        // ========== ГОЛОСОВОЕ ОПОВЕЩЕНИЕ ==========
        function speak(text) {
            if ('speechSynthesis' in window) {
                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = 'ru-RU';
                utterance.rate = 1.2;
                window.speechSynthesis.cancel();
                window.speechSynthesis.speak(utterance);
            }
        }

        // ========== ФИЛЬТРАЦИЯ ==========
        window.filterSignals = function() {
            const searchTerm = document.getElementById('searchFilter').value.toLowerCase();
            const container = document.getElementById('signalsContainer');
            const cards = container.querySelectorAll('.signal-card');
            cards.forEach(card => {
                const symbol = card.getAttribute('data-symbol') || '';
                if (symbol.toLowerCase().includes(searchTerm)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        };

        // ========== ОТОБРАЖЕНИЕ СИГНАЛОВ ==========
        function renderSignals(signals) {
            const container = document.getElementById('signalsContainer');
            
            if (!signals || signals.length === 0) {
                container.innerHTML = '<div style="text-align: center; padding: 40px;">📭 Нет активных сигналов</div>';
                return;
            }
            
            let html = '';
            for (let i = 0; i < signals.length; i++) {
                const s = signals[i];
                const actionClass = s.action === 'buy' ? 'buy' : 'sell';
                const actionText = s.action === 'buy' ? '🟢 BUY' : '🔴 SELL';
                const time = s.timestamp ? new Date(s.timestamp).toLocaleTimeString() : new Date().toLocaleTimeString();
                const price = s.price ? `$${Number(s.price).toLocaleString()}` : '—';
                const rsi = s.rsi || '—';
                const reason = s.reason ? (s.reason.length > 80 ? s.reason.slice(0, 80) + '...' : s.reason) : 'Мульти-индикаторный сигнал';
                
                html += `
                    <div class="signal-card" data-symbol="${s.symbol}" onclick="openBybitChart('${s.symbol}')">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span class="signal-symbol">💰 ${s.symbol}</span>
                            <span class="signal-action ${actionClass}">${actionText}</span>
                        </div>
                        <div style="display: flex; gap: 20px; margin-top: 10px; font-size: 12px; color: #aaa;">
                            <span>💵 ${price}</span>
                            <span>📊 RSI: ${rsi}</span>
                            <span>⏰ ${time}</span>
                        </div>
                        <div style="margin-top: 8px; font-size: 11px; color: #888;">📝 ${reason}</div>
                    </div>
                `;
            }
            container.innerHTML = html;
        }

        // ========== ОБНОВЛЕНИЕ СТАТИСТИКИ ==========
        function updateStats(signals) {
            const total = signals.length;
            const buys = signals.filter(s => s.action === 'buy').length;
            const sells = total - buys;
            document.getElementById('totalSignals').innerText = total;
            document.getElementById('buySignals').innerText = buys;
            document.getElementById('sellSignals').innerText = sells;
        }

        // ========== ЗАГРУЗКА СИГНАЛОВ ==========
        async function loadSignals() {
            try {
                const response = await fetch('https://ai-trade-machine.onrender.com/api/signals');
                const signals = await response.json();
                
                if (signals && signals.length > 0) {
                    if (signals.length > previousSignalsCount) {
                        playAlertSound();
                        speak(`Новый сигнал! ${signals[0].action} по ${signals[0].symbol}`);
                    }
                    previousSignalsCount = signals.length;
                    
                    renderSignals(signals);
                    updateStats(signals);
                } else {
                    document.getElementById('signalsContainer').innerHTML = '<div style="text-align: center; padding: 40px;">📭 Нет активных сигналов</div>';
                }
            } catch (error) {
                console.log('Ошибка подключения:', error);
                document.getElementById('signalsContainer').innerHTML = `
                    <div style="text-align: center; padding: 40px;">
                        ⚠️ Ожидание подключения к торговому серверу...<br>
                        <small style="color: #666;">https://ai-trade-machine.onrender.com</small>
                    </div>
                `;
                
                // Тестовые данные
                const testSignals = [
                    { symbol: 'BTC/USDT', action: 'buy', price: 68500, rsi: 32, timestamp: new Date().toISOString(), reason: 'RSI перепродан, EMA бычий' },
                    { symbol: 'ETH/USDT', action: 'sell', price: 3450, rsi: 72, timestamp: new Date().toISOString(), reason: 'RSI перекуплен, MACD медвежий' },
                    { symbol: 'SOL/USDT', action: 'buy', price: 165, rsi: 28, timestamp: new Date().toISOString(), reason: 'Стохастик на дне' },
                ];
                renderSignals(testSignals);
                updateStats(testSignals);
            }
        }

        // ========== ВРЕМЯ ==========
        function updateTime() {
            const now = new Date();
            document.getElementById('liveTime').innerHTML = now.toLocaleTimeString('ru-RU');
        }

        // ========== ЗАПУСК ==========
        updateTime();
        setInterval(updateTime, 1000);
        loadSignals();
        setInterval(loadSignals, 10000);
    </script>
</body>
</html>
