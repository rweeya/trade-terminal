<!DOCTYPE html>
<html>
<head>
    <title>Auto Trade</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: linear-gradient(135deg, #0a0e27, #000);
            color: #00ff88;
            font-family: 'Courier New', monospace;
            min-height: 100vh;
            padding: 20px;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        h1 {
            text-align: center;
            font-size: 48px;
            margin-bottom: 30px;
            text-shadow: 0 0 20px #00ff88;
        }
        .stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }
        .stat-card {
            background: rgba(0, 255, 136, 0.1);
            border: 1px solid #00ff88;
            border-radius: 15px;
            padding: 20px;
            text-align: center;
        }
        .stat-value {
            font-size: 36px;
            font-weight: bold;
        }
        .stat-label {
            font-size: 12px;
            margin-top: 10px;
            color: #aaa;
        }
        .signal-card {
            background: rgba(0, 255, 136, 0.05);
            border: 1px solid #00ff88;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all 0.3s;
        }
        .signal-card:hover {
            background: rgba(0, 255, 136, 0.15);
            transform: translateX(5px);
        }
        .signal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }
        .symbol {
            font-size: 20px;
            font-weight: bold;
        }
        .action {
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: bold;
        }
        .buy {
            background: #00ff88;
            color: #000;
        }
        .sell {
            background: #ff4444;
            color: #fff;
        }
        .details {
            display: flex;
            gap: 20px;
            font-size: 12px;
            color: #aaa;
        }
        .footer {
            text-align: center;
            margin-top: 30px;
            padding: 20px;
            color: #555;
        }
        input {
            width: 100%;
            padding: 12px;
            margin-bottom: 20px;
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid #00ff88;
            color: #00ff88;
            border-radius: 10px;
            font-size: 16px;
        }
        input:focus {
            outline: none;
            box-shadow: 0 0 10px #00ff88;
        }
        .signals-list {
            max-height: 500px;
            overflow-y: auto;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>⚡ AUTO TRADE ⚡</h1>
        
        <div class="stats">
            <div class="stat-card">
                <div class="stat-value" id="totalSignals">0</div>
                <div class="stat-label">ВСЕГО СИГНАЛОВ</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" id="buySignals">0</div>
                <div class="stat-label">BUY</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" id="sellSignals">0</div>
                <div class="stat-label">SELL</div>
            </div>
        </div>
        
        <input type="text" id="searchInput" placeholder="🔍 Поиск монеты (BTC, ETH, SOL...)">
        
        <div class="signals-list" id="signalsList">
            <div style="text-align: center; padding: 40px;">Загрузка сигналов...</div>
        </div>
        
        <div class="footer">
            🔥 Клик по сигналу → открывает график Bybit | Обновление каждые 10 секунд
        </div>
    </div>
    
    <script>
        let allSignals = [];
        
        function openChart(symbol) {
            let clean = symbol.replace('/USDT', '').replace('USDT', '');
            window.open(`https://www.bybit.com/trade/spot/${clean}/USDT?interval=60`, '_blank');
        }
        
        function filterSignals() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const filtered = allSignals.filter(s => s.symbol.toLowerCase().includes(search));
            renderSignals(filtered);
        }
        
        function renderSignals(signals) {
            const container = document.getElementById('signalsList');
            if (!signals.length) {
                container.innerHTML = '<div style="text-align: center; padding: 40px;">📭 Нет сигналов</div>';
                return;
            }
            
            let html = '';
            for (let s of signals) {
                const actionClass = s.action === 'buy' ? 'buy' : 'sell';
                const actionText = s.action === 'buy' ? '🟢 BUY' : '🔴 SELL';
                const time = new Date(s.timestamp).toLocaleTimeString();
                const price = s.price ? `$${Number(s.price).toLocaleString()}` : '—';
                
                html += `
                    <div class="signal-card" onclick="openChart('${s.symbol}')">
                        <div class="signal-header">
                            <span class="symbol">💰 ${s.symbol}</span>
                            <span class="action ${actionClass}">${actionText}</span>
                        </div>
                        <div class="details">
                            <span>💵 ${price}</span>
                            <span>📊 RSI: ${s.rsi || '—'}</span>
                            <span>⏰ ${time}</span>
                        </div>
                        <div style="margin-top: 8px; font-size: 11px; color: #888;">📝 ${s.reason || 'Сигнал от AI'}</div>
                    </div>
                `;
            }
            container.innerHTML = html;
        }
        
        function updateStats(signals) {
            document.getElementById('totalSignals').innerText = signals.length;
            document.getElementById('buySignals').innerText = signals.filter(s => s.action === 'buy').length;
            document.getElementById('sellSignals').innerText = signals.filter(s => s.action === 'sell').length;
        }
        
        async function loadSignals() {
            try {
                const response = await fetch('/api/signals');
                allSignals = await response.json();
                updateStats(allSignals);
                renderSignals(allSignals);
            } catch(e) {
                console.error('Ошибка:', e);
                document.getElementById('signalsList').innerHTML = '<div style="text-align: center; padding: 40px;">❌ Ошибка загрузки</div>';
            }
        }
        
        loadSignals();
        setInterval(loadSignals, 10000);
        
        document.getElementById('searchInput').addEventListener('keyup', filterSignals);
    </script>
</body>
</html>
